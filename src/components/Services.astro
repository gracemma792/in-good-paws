---
const services = [
  {
    icon: '🦮',
    title: 'Private Walks',
    desc: 'One-on-one walks tailored to your dog’s pace and needs. Calm, personal, and fully focused on your pup.',
    price: '$50 (45 min) · $65 (60 min)',
    highlight: true,
  },
  {
    icon: '🐕‍🦺',
    title: 'Group Walks',
    desc: 'Social walks with a small group of friendly dogs. We walk up to 6 dogs together (3 each) for a safe, fun experience.',
    price: '$45 · +$30 second dog',
    highlight: false,
  },
  {
    icon: '🏡',
    title: 'Day Sitting',
    desc: 'Care in your home while you’re out for the day. Perfect for dogs who need company, attention, or routine.',
    price: 'Contact us',
    highlight: false,
  },
  {
    icon: '🐾',
    title: 'Drop-In Visits',
    desc: 'Feeding, playtime, and check-ins while you’re out. Great for busy days or quick visits.',
    price: '$35 (30 min) · $60 (60 min)',
    highlight: false,
  },
  {
    icon: '🌙',
    title: 'Pet Sitting',
    desc: 'Overnight or extended care in your home while you travel. We keep your dog comfortable in their own space.',
    price: '$60 per night | Contact us',
    highlight: false,
  },
];
---

<section class="services" id="services">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">What We Offer</span>
      <h2 class="section-title">Walks & Care<br/><em>your dog's needs</em></h2>
      <p class="section-subtitle">
  Simple, thoughtful care tailored to each dog — whether it’s a quick walk or a full day of company.
</p>
    </div>

    <div class="services__grid">
      {services.map(s => (
        <div class={`service-card ${s.highlight ? 'service-card--highlight' : ''}`}>
          <div class="service-card__icon">{s.icon}</div>
          <h3 class="service-card__title">{s.title}</h3>
          <p class="service-card__desc">{s.desc}</p>
          <div class="service-card__footer">
            <span class="service-card__price">{s.price}</span>
            <a href="#contact" class="service-card__link">Book →</a>
          </div>
        </div>
      ))}
    </div>

    <div class="services__note">
      <span>🐾</span>
      <p>Fill out an enquiry and we’ll get back to you within 24 hours to organise what you need.</p>
  </div>
</section>

<style>
  .services {
    padding: 100px 0;
    background: var(--warm-white);
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-tag {
    display: inline-block;
    background: var(--moss-light);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: var(--radius-pill);
    margin-bottom: 16px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--bark-dark);
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .section-title em {
    color: var(--moss);
    font-style: italic;
  }

  .section-subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .service-card {
    background: var(--cream);
    border: 2px solid var(--sand);
    border-radius: var(--radius-md);
    padding: 32px 28px;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--bark);
  }

  .service-card--highlight {
    background: var(--bark-dark);
    border-color: var(--bark-dark);
    color: var(--cream);
  }

  .service-card--highlight .service-card__desc {
    color: rgba(250,246,239,0.75);
  }

  .service-card--highlight .service-card__price {
    color: #F5C842;
  }

  .service-card--highlight .service-card__link {
    color: var(--cream);
    border-color: rgba(255,255,255,0.3);
  }

  .service-card--highlight:hover {
    border-color: var(--bark-dark);
    box-shadow: 0 8px 40px rgba(61, 43, 31, 0.4);
  }

  .service-card__icon {
    font-size: 2.2rem;
    margin-bottom: 16px;
  }

  .service-card__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .service-card__desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .service-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid var(--sand);
  }

  .service-card--highlight .service-card__footer {
    border-color: rgba(255,255,255,0.15);
  }

  .service-card__price {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--moss);
  }

  .service-card__link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--bark);
    padding: 6px 14px;
    border: 1.5px solid var(--sand);
    border-radius: var(--radius-pill);
    transition: all 0.2s;
  }

  .service-card__link:hover {
    background: var(--bark);
    color: white;
    border-color: var(--bark);
  }

  .services__note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: var(--sand);
    border-radius: var(--radius-md);
    padding: 20px 32px;
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .services__note span { font-size: 1.2rem; }

  @media (max-width: 900px) {
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .services__grid { grid-template-columns: 1fr; }
  }
</style>
