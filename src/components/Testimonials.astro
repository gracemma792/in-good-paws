---
const reviews = [
  {
    name: 'Sarah M.',
    suburb: 'Newtown',
    dog: 'Biscuit, Border Collie',
    rating: 5,
    text: 'In Good Paws has been an absolute lifesaver. Biscuit comes home tired and happy every single time. The photos they send mid-walk make my whole work day.',
    emoji: '🐕',
  },
  {
    name: 'James & Priya T.',
    suburb: 'Glebe',
    dog: 'Mango, Golden Retriever',
    rating: 5,
    text: 'We\'ve tried a few dog walkers but nobody compares. They actually care about Mango as an individual, know his quirks, and always go the extra mile.',
    emoji: '🦮',
  },
  {
    name: 'Rachel K.',
    suburb: 'Surry Hills',
    dog: 'Pepper, Dachshund',
    rating: 5,
    text: 'My little Pepper is very anxious around new people. They were so patient with her during the meet & greet. Now she sprints to the door when they arrive!',
    emoji: '🐶',
  },
  {
    name: 'Tom B.',
    suburb: 'Marrickville',
    dog: 'Duke, Staffy',
    rating: 5,
    text: 'Trustworthy, professional, and genuinely lovely people. I\'ve been using them for over a year and would never go anywhere else. Duke absolutely adores them.',
    emoji: '🐾',
  },
];
---

<section class="testimonials" id="testimonials">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Happy Clients</span>
      <h2 class="section-title">Don't just take<br/><em>our word for it</em></h2>
    </div>

    <div class="reviews__grid">
      {reviews.map((r, i) => (
        <div class="review-card" style={`animation-delay: ${i * 0.1}s`}>
          <div class="review-card__top">
            <div class="review-card__avatar">{r.emoji}</div>
            <div>
              <strong class="review-card__name">{r.name}</strong>
              <p class="review-card__meta">{r.suburb} · {r.dog}</p>
            </div>
            <div class="review-card__stars">
              {'★'.repeat(r.rating)}
            </div>
          </div>
          <p class="review-card__text">"{r.text}"</p>
        </div>
      ))}
    </div>

    <div class="reviews__summary">
      <div class="reviews__score">
        <span class="reviews__big-star">★</span>
        <div>
          <strong>4.9 / 5</strong>
          <p>Based on 80+ Google reviews</p>
        </div>
      </div>
      <a href="https://maps.google.com" target="_blank" rel="noopener" class="btn btn--ghost">
        Read all reviews →
      </a>
    </div>
  </div>
</section>

<style>
  .testimonials {
    padding: 100px 0;
    background: var(--warm-white);
  }

  .reviews__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .review-card {
    background: var(--cream);
    border: 2px solid var(--sand);
    border-radius: var(--radius-md);
    padding: 28px;
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .review-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .review-card__top {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }

  .review-card__avatar {
    font-size: 2rem;
    width: 52px;
    height: 52px;
    background: var(--sand);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .review-card__name {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--bark-dark);
  }

  .review-card__meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 2px 0 0;
  }

  .review-card__stars {
    margin-left: auto;
    color: #F5C842;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .review-card__text {
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.7;
    font-style: italic;
  }

  .reviews__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bark-dark);
    border-radius: var(--radius-md);
    padding: 28px 36px;
    color: white;
  }

  .reviews__score {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .reviews__big-star {
    font-size: 3rem;
    color: #F5C842;
    line-height: 1;
  }

  .reviews__score strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
  }

  .reviews__score p {
    font-size: 0.85rem;
    opacity: 0.7;
    margin-top: 4px;
  }

  .reviews__summary .btn--ghost {
    border-color: rgba(255,255,255,0.3);
    color: white;
  }

  .reviews__summary .btn--ghost:hover {
    background: rgba(255,255,255,0.1);
  }

  @media (max-width: 700px) {
    .reviews__grid { grid-template-columns: 1fr; }
    .reviews__summary {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
</style>
