---
---

<section class="hero">
  <!-- Background blobs -->
  <div class="hero__blob hero__blob--1"></div>
  <div class="hero__blob hero__blob--2"></div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__badge">🐾 Dog walking in Five Dock, Wareemba & surrounds</div>
<h1 class="hero__title">
  Walks made with<br/>
  <em>love, care</em><br/>
  and plenty of tail wags
</h1>
<p class="hero__desc">
 Run by two best friends, Emma and Grace, In Good Paws offers thoughtful dog walks and day sitting for local pups.
</p>
      <div class="hero__actions">
        <a href="#contact" class="btn btn--primary">Send an Enquiry</a>
        <a href="#services" class="btn btn--ghost">See Our Services</a>
      </div>
    </div>

    <div class="hero__photos">
  <div class="hero__photo-card hero__photo-card--tilt-left">
    <img src="/in-good-paws/IMG_7484.jpg" alt="Emma with a dog" loading="eager" fetchpriority="high" /> />
  </div>

  <div class="hero__photo-card hero__photo-card--main">
    <img src="/in-good-paws/annieham.png" alt="Two dogs together" loading="eager" fetchpriority="high" /> />
  </div>

  <div class="hero__photo-card hero__photo-card--tilt-right">
<img class="photo-grace" src="/in-good-paws/IMG_1514%202.JPG" alt="Grace with a dog" loading="eager" fetchpriority="high" /></div>
</div>

  <div class="hero__scroll">
    <span>Scroll to explore</span>
    <div class="scroll-arrow">↓</div>
  </div>
</section>

<style>
.hero__photos {
  display: grid;
  grid-template-columns: 1fr 1.2fr 1fr;
  gap: 20px;
  align-items: center;
  min-height: 500px;
}

.hero__photo-card {
  width: 100%;
  height: 420px;
  background: var(--warm-white);
  padding: 12px;
  border-radius: 32px;
  box-shadow: var(--shadow-md);
  overflow: hidden;
  border: 2px solid var(--sand);
  transition: transform 0.3s ease;
}

.hero__photo-card:hover {
  transform: translateY(-6px);
}

.hero__photo-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 24px;
}
.photo-grace {
  object-position: left center;
}

/* middle image bigger */
.hero__photo-card--main {
  height: 500px;
  transform: translateY(-10px);
  z-index: 2;
}

/* subtle tilt only */
.hero__photo-card--tilt-left {
  transform: rotate(-3deg);
}

.hero__photo-card--tilt-right {
  transform: rotate(3deg);
}

@media (max-width: 900px) {
  .hero__photos {
    gap: 12px;
    min-height: auto;
  }

  .hero__photo-card {
    height: 240px;
  }

  .hero__photo-card--main {
    height: 280px;
  }
}

@media (max-width: 600px) {
  .hero__photos {
    grid-template-columns: 1fr;
  }

  .hero__photo-card,
  .hero__photo-card--main {
    width: 100%;
    height: 320px;
    transform: none;
  }
}

  .hero__photo-card,
  .hero__photo-card--main {
    width: 85%;
    height: 260px;
    transform: none;
  }
}
.hero {
  min-height: auto;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 140px 0 50px;
}

  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    pointer-events: none;
  }

  .hero__blob--1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, #C8DDE8, transparent);
    top: -200px; right: -200px;
  }

  .hero__blob--2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, #E8DDD0, transparent);
    bottom: -100px; left: -100px;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
.hero__inner {
  margin-bottom: 20px;
}

  .hero__content {
    animation: fadeUp 0.8s ease both;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--sand);
    color: var(--bark-dark);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: var(--radius-pill);
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease 0.1s both;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    line-height: 1.1;
    color: var(--bark-dark);
    letter-spacing: -0.02em;
    margin-bottom: 20px;
    animation: fadeUp 0.8s ease 0.15s both;
  }

  .hero__title em {
    color: var(--moss);
    font-style: italic;
  }

  .hero__desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 440px;
    margin-bottom: 36px;
    animation: fadeUp 0.8s ease 0.2s both;
  }

  .hero__actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    animation: fadeUp 0.8s ease 0.25s both;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .btn--primary {
    background: var(--bark);
    color: var(--cream);
  }

  .btn--primary:hover {
    background: var(--bark-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(107, 76, 53, 0.35);
  }

  .btn--ghost {
    border: 2px solid var(--sand);
    color: var(--text);
  }

  .btn--ghost:hover {
    background: var(--sand);
    transform: translateY(-2px);
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: 24px;
    animation: fadeUp 0.8s ease 0.3s both;
  }

  .stat strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--bark-dark);
  }

  .stat span {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .stat__divider {
    width: 1px;
    height: 36px;
    background: var(--sand);
  }

  /* Visual side */
  .hero__visual {
    position: relative;
    height: 480px;
    animation: fadeIn 1s ease 0.4s both;
  }

  .hero__card {
    position: absolute;
    background: var(--warm-white);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .hero__card--main {
    width: 340px;
    height: 360px;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    overflow: hidden;
    border-radius: var(--radius-lg);
    animation: float 5s ease-in-out infinite;
  }

  .dog-svg {
    width: 100%;
    height: 100%;
  }

  .tail {
    transform-origin: 212px 215px;
    animation: wagTail 0.6s ease-in-out infinite;
  }

  .hero__card--badge {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    left: -20px;
    bottom: 80px;
    font-size: 1.4rem;
  }

  .hero__card--badge strong {
    font-size: 0.9rem;
    color: var(--bark-dark);
  }

  .hero__card--badge p {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0;
  }

  .hero__card--ping {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    right: -10px;
    top: 20px;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .ping {
    width: 10px; height: 10px;
    background: #4CAF50;
    border-radius: 50%;
    position: relative;
    flex-shrink: 0;
  }

  .ping::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: #4CAF50;
    opacity: 0.3;
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.8); opacity: 0; }
  }

 .hero__scroll {
  position: static;
  transform: none;
  margin: 30px auto 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  font-size: 0.75rem;
  color: var(--text-muted);
  animation: fadeIn 1s ease 1s both;
}

  .scroll-arrow {
    animation: float 2s ease-in-out infinite;
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__desc { margin: 0 auto 36px; }
    .hero__actions { justify-content: center; }
    .hero__stats { justify-content: center; }

    .hero__visual {
      height: 380px;
      order: -1;
    }

    .hero__card--main {
      width: 280px;
      height: 300px;
    }

    .hero__card--badge { left: 0; }
    .hero__card--ping { right: 0; }
  }
</style>
